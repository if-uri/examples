{
  "version": "urirun.bindings.v2",
  "bindings": {
    "social://linkedin.local/post/command/publish": {
      "kind": "command",
      "adapter": "local-function",
      "ref": "nl_autonomy:publish_local",
      "python": {
        "type": "python",
        "module": "nl_autonomy",
        "export": "publish_local"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "post": {"type": "string", "description": "Text to publish on the local fake LinkedIn feed."},
          "hostname": {"type": "string", "default": "linkedin.local"},
          "host": {"type": "string", "default": "127.0.0.1"},
          "port": {"type": "integer", "default": 0},
          "env": {"type": "string", "default": ""},
          "keep_browser": {"type": "boolean", "default": false}
        }
      },
      "policy": {"allowExecute": true},
      "meta": {
        "label": "Publish a fake local LinkedIn post",
        "description": "Starts the local mock, logs in with .env credentials, publishes, and verifies the local feed."
      }
    }
  }
}
