{
  "version": "urirun.bindings.v2",
  "bindings": {
    "social://linkedin.com/post/command/publish": {
      "kind": "command",
      "adapter": "local-function",
      "ref": "nl_autonomy:publish_local",
      "python": {
        "type": "python",
        "module": "nl_autonomy",
        "export": "publish_local"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "post": {"type": "string", "description": "Text to publish on the LinkedIn feed."},
          "port": {"type": "integer", "default": 0},
          "env": {"type": "string", "default": "", "description": "Path to .env with route/domain/host settings."},
          "keep_browser": {"type": "boolean", "default": false}
        }
      },
      "policy": {"allowExecute": true},
      "meta": {
        "label": "Publish a LinkedIn post",
        "description": "Loads route/domain/host settings from .env, starts the site, publishes, and verifies the feed."
      }
    }
  }
}
