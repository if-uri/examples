{
  "version": "urirun.bindings.v2",
  "bindings": {
    "env://lenovo/runtime/query/health": {
      "kind": "command",
      "adapter": "argv-template",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      },
      "argv": [
        "/home/tom/github/if-uri/examples/31-llm-remote-office/../../../tellmesh/urisys-node/.venv/bin/python",
        "-c",
        "import json,platform,socket,os;print(json.dumps({'host':socket.gethostname(),'platform':platform.platform(),'cwd':os.getcwd()}))"
      ],
      "policy": {
        "allowExecute": true,
        "maxArgs": 8
      },
      "meta": {
        "label": "Node runtime health"
      }
    },
    "log://lenovo/session/command/write": {
      "kind": "command",
      "adapter": "argv-template",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "argv": [
        "/home/tom/github/if-uri/examples/31-llm-remote-office/../../../tellmesh/urisys-node/.venv/bin/python",
        "-c",
        "import json,pathlib,sys,time;p=pathlib.Path('/tmp/urirun-lenovo.log');p.open('a').write(json.dumps({'at':time.time(),'text':sys.argv[1]})+chr(10));print(json.dumps({'wrote':sys.argv[1]}))",
        "{text}"
      ],
      "policy": {
        "allowExecute": true,
        "maxArgs": 8
      },
      "meta": {
        "label": "Write local node log entry"
      }
    },
    "log://lenovo/session/query/recent": {
      "kind": "command",
      "adapter": "argv-template",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "limit": {
            "type": "integer",
            "default": 20,
            "minimum": 1,
            "maximum": 200
          }
        }
      },
      "argv": [
        "/home/tom/github/if-uri/examples/31-llm-remote-office/../../../tellmesh/urisys-node/.venv/bin/python",
        "-c",
        "import json,pathlib,sys;p=pathlib.Path('/tmp/urirun-lenovo.log');print(json.dumps({'lines':p.read_text().splitlines()[-int(sys.argv[1]):] if p.exists() else []}))",
        "{limit}"
      ],
      "policy": {
        "allowExecute": true,
        "maxArgs": 8
      },
      "meta": {
        "label": "Read local node log entries"
      }
    },
    "proc://lenovo/process/query/list": {
      "kind": "command",
      "adapter": "argv-template",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "limit": {
            "type": "integer",
            "default": 12,
            "minimum": 1,
            "maximum": 50
          }
        }
      },
      "argv": [
        "/home/tom/github/if-uri/examples/31-llm-remote-office/../../../tellmesh/urisys-node/.venv/bin/python",
        "-c",
        "import json,subprocess,sys;out=subprocess.run(['ps','-eo','pid,comm,%cpu','--sort=-%cpu'],capture_output=True,text=True).stdout.splitlines()[:int(sys.argv[1])+1];print(json.dumps({'processes':out}))",
        "{limit}"
      ],
      "policy": {
        "allowExecute": true,
        "maxArgs": 8
      },
      "meta": {
        "label": "List top local processes"
      }
    },
